# Worker Service Environment Variables

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Neo4j Configuration
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Celery Configuration
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Logging
LOG_LEVEL=INFO

# Graphify semantic extraction runtime
GRAPHIFY_LLM_API_KEY=
GRAPHIFY_LLM_MODEL=
GRAPHIFY_LLM_BASE_URL=
GRAPHIFY_LLM_ANTHROPIC_VERSION=2023-06-01
GRAPHIFY_LLM_ANTHROPIC_THINKING_DISABLED=true
GRAPHIFY_LLM_TIMEOUT_SECONDS=120
GRAPHIFY_LLM_MAX_CHUNK_CHARS=50000
GRAPHIFY_LLM_MAX_OUTPUT_TOKENS=4000
